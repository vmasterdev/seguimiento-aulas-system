generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Period {
  id              String   @id @default(cuid())
  code            String   @unique
  label           String
  semester        Int
  modality        String
  executionPolicy String   @default("APPLIES") // APPLIES | AUTO_PASS
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  courses         Course[]
  sampleGroups    SampleGroup[]
  outbox          OutboxMessage[]
}

model Teacher {
  id         String   @id
  sourceId   String?
  documentId String?
  fullName   String
  email      String?
  email2     String?
  costCenter String?
  coordination String?
  campus     String?
  region     String?
  escalafon         String?
  dedicacion        String?
  tipoContrato      String?
  fechaInicio       DateTime?
  fechaFin          DateTime?
  antiguedadText    String?
  programaAcademico String?
  programaCodigo    String?
  previousEmployment Boolean  @default(false)
  extraJson  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  courses     Course[]
  sampleGroups SampleGroup[]
  outbox      OutboxMessage[]

  @@index([sourceId])
  @@index([documentId])
  @@index([coordination])
}

model Coordinator {
  id         String   @id @default(cuid())
  programId  String
  programKey String
  fullName   String
  email      String
  campus     String?
  region     String?
  sourceSheet String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  outbox     OutboxMessage[]

  @@unique([programKey, email])
  @@index([programId])
  @@index([programKey])
}

model Course {
  id              String   @id @default(cuid())
  nrc             String
  periodId        String
  period          Period   @relation(fields: [periodId], references: [id])
  campusCode      String?
  programCode     String?
  programName     String?
  subjectName     String?
  moment          String?
  salon           String?
  salon1          String?
  teacherId       String?
  teacher         Teacher? @relation(fields: [teacherId], references: [id])
  templateDeclared String?
  d4FlagLegacy    Boolean  @default(false)
  bannerStartDate String?
  bannerEndDate   String?
  rawJson         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  moodleCheck     MoodleCheck?
  attendanceReports MoodleAttendanceReport[]
  activityReports MoodleActivityReport[]
  participantReports MoodleParticipantReport[]
  bannerEnrollmentReports BannerEnrollmentReport[]
  evaluations     Evaluation[]
  selectedInGroups SampleGroup[] @relation("SelectedCourse")

  @@unique([nrc, periodId])
  @@index([periodId, nrc])
  @@index([teacherId])
}

model MoodleCheck {
  id        String   @id @default(cuid())
  courseId  String   @unique
  course    Course   @relation(fields: [courseId], references: [id])

  status    String   @default("PENDIENTE")
  detectedTemplate String?
  errorCode String?
  moodleCourseUrl String?
  moodleCourseId String?
  resolvedModality String?
  resolvedBaseUrl String?
  searchQuery String?
  resolvedAt DateTime?
  attempts  Int      @default(0)
  lastAttemptAt DateTime?
  evidenceScreenshotPath String?
  evidenceHtmlPath String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SampleGroup {
  id        String   @id @default(cuid())
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  periodId  String
  period    Period   @relation(fields: [periodId], references: [id])

  programCode String
  moment      String
  modality    String
  template    String

  selectedCourseId String?
  selectedCourse   Course? @relation("SelectedCourse", fields: [selectedCourseId], references: [id])

  selectionSeed String
  createdAt DateTime @default(now())

  @@unique([teacherId, periodId, programCode, moment, modality, template])
  @@index([periodId, moment])
}

model Evaluation {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])

  phase     String
  checklist Json?
  score     Float
  observations String?
  computedAt DateTime @default(now())
  replicatedFromCourseId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, phase])
  @@index([phase, computedAt])
}

model OutboxMessage {
  id         String   @id @default(cuid())
  audience   String
  teacherId  String?
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  coordinatorId String?
  coordinator Coordinator? @relation(fields: [coordinatorId], references: [id])

  programCode String?
  periodId    String
  period      Period @relation(fields: [periodId], references: [id])

  phase      String
  moment     String
  subject    String
  recipientName String?
  recipientEmail String?
  cc         String?
  htmlBody   String
  emlPath    String?
  status     String   @default("DRAFT")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([periodId, phase, moment, status])
  @@index([teacherId, status])
  @@index([coordinatorId, status])
  @@index([audience, recipientEmail])
}

model AuditLog {
  id         String   @id @default(cuid())
  actor      String
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())
}

model MoodleAttendanceReport {
  id                 String                  @id @default(cuid())
  courseId           String
  course             Course                  @relation(fields: [courseId], references: [id])
  sourceRelativePath String                  @unique
  importGroupKey     String?
  label              String?
  courseLabel        String?
  groupLabel         String?
  importedAt         DateTime                @default(now())
  reportCreatedAt    DateTime?
  totalStudents      Int                     @default(0)
  totalSessions      Int                     @default(0)
  coverageStart      String?
  coverageEnd        String?
  summaryJson        Json?
  sessions           MoodleAttendanceSession[]
  records            MoodleAttendanceRecord[]
  entries            MoodleAttendanceEntry[]

  @@index([courseId, importedAt])
  @@index([courseId, importGroupKey])
  @@index([coverageStart])
  @@index([coverageEnd])
}

model MoodleAttendanceSession {
  id               String                  @id @default(cuid())
  reportId         String
  report           MoodleAttendanceReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sessionLabel     String
  sessionDay       String?
  sessionAt        DateTime?
  columnIndex      Int
  statusCodeTotals Json?
  entries          MoodleAttendanceEntry[]

  @@index([reportId, columnIndex])
  @@index([sessionDay])
}

model MoodleAttendanceRecord {
  id              String                  @id @default(cuid())
  reportId        String
  report          MoodleAttendanceReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fullName        String
  firstName       String?
  lastName        String?
  moodleUserId    String?
  institutionalId String?
  email           String?
  sessionsTaken   Int?
  scoreLabel      String?
  percentage      Float?
  entries         MoodleAttendanceEntry[]

  @@index([reportId])
  @@index([fullName])
  @@index([email])
}

model MoodleAttendanceEntry {
  id           String                  @id @default(cuid())
  reportId     String
  report       MoodleAttendanceReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  sessionId    String
  session      MoodleAttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recordId     String
  record       MoodleAttendanceRecord  @relation(fields: [recordId], references: [id], onDelete: Cascade)
  rawValue     String?
  statusCode   String?
  present      Boolean?
  justified    Boolean?
  pointsEarned Float?
  pointsPossible Float?

  @@unique([sessionId, recordId])
  @@index([reportId, statusCode])
}

model MoodleActivityReport {
  id                 String               @id @default(cuid())
  courseId           String
  course             Course               @relation(fields: [courseId], references: [id])
  sourceRelativePath String               @unique
  importGroupKey     String?
  importedAt         DateTime             @default(now())
  totalEvents        Int                  @default(0)
  uniqueUsers        Int                  @default(0)
  coverageStart      String?
  coverageEnd        String?
  summaryJson        Json?
  events             MoodleActivityEvent[]

  @@index([courseId, importedAt])
  @@index([courseId, importGroupKey])
  @@index([coverageStart])
  @@index([coverageEnd])
}

model MoodleActivityEvent {
  id            String               @id @default(cuid())
  reportId      String
  report        MoodleActivityReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  eventAt       DateTime?
  eventDay      String?
  actorName     String
  actorKey      String?
  actorCategory String?
  affectedUser  String?
  eventContext  String?
  component     String?
  eventName     String?
  description   String?
  origin        String?
  ipAddress     String?

  @@index([reportId, eventDay])
  @@index([actorName])
  @@index([actorCategory])
  @@index([component])
  @@index([eventName])
}

model MoodleParticipantReport {
  id                 String                    @id @default(cuid())
  courseId           String
  course             Course                    @relation(fields: [courseId], references: [id])
  sourceRelativePath String                    @unique
  importGroupKey     String?
  importedAt         DateTime                  @default(now())
  courseLabel        String?
  totalParticipants  Int                       @default(0)
  roleCounts         Json?
  summaryJson        Json?
  participants       MoodleParticipantRecord[]

  @@index([courseId, importedAt])
  @@index([courseId, importGroupKey])
}

model MoodleParticipantRecord {
  id                String                  @id @default(cuid())
  reportId          String
  report            MoodleParticipantReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fullName          String
  email             String?
  moodleUserId      String?
  institutionalId   String?
  rolesLabel        String?
  rolesJson         Json?
  groupsLabel       String?
  lastAccessLabel   String?
  statusLabel       String?
  actorCategory     String?
  rawJson           Json?

  @@index([reportId])
  @@index([fullName])
  @@index([email])
  @@index([actorCategory])
}

model BannerEnrollmentReport {
  id                 String                   @id @default(cuid())
  courseId           String
  course             Course                   @relation(fields: [courseId], references: [id])
  sourceRelativePath String                   @unique
  importGroupKey     String?
  importedAt         DateTime                 @default(now())
  sourceLabel        String?
  totalStudents      Int                      @default(0)
  summaryJson        Json?
  students           BannerEnrollmentRecord[]

  @@index([courseId, importedAt])
  @@index([courseId, importGroupKey])
}

model BannerEnrollmentRecord {
  id                String                 @id @default(cuid())
  reportId          String
  report            BannerEnrollmentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fullName          String
  firstName         String?
  lastName          String?
  institutionalId   String?
  email             String?
  statusLabel       String?
  rawJson           Json?

  @@index([reportId])
  @@index([fullName])
  @@index([email])
  @@index([institutionalId])
}
