{
  "name": "@seguimiento/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --enable-source-maps dist/apps/api/src/main.js",
    "build": "tsc -p tsconfig.json",
    "lint": "echo \"(api) lint TBD\"",
    "test": "echo \"(api) test TBD\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "sidecar:adapter": "tsx scripts/moodle_url_resolver_adapter.ts",
    "sidecar:adapter:dry": "tsx scripts/moodle_url_resolver_adapter.ts --dry-run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "@prisma/client": "^5.18.0",
    "@seguimiento/shared": "workspace:*",
    "bullmq": "^5.13.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "reflect-metadata": "^0.2.2",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/multer": "^1.4.12",
    "prisma": "^5.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  }
}
