NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001
INTERNAL_API_BASE_URL=http://127.0.0.1:3001

# Ruta al runner externo de Banner. Recomendado en un path Linux nativo.
BANNER_PROJECT_ROOT=/home/<usuario>/banner-docente-runner

# Opcional: plantilla para abrir Moodle por NRC desde la UI.
NEXT_PUBLIC_MOODLE_URL_TEMPLATE=

# Opcional: copia Linux estable del API usada por scripts/dev-stack.sh cuando el repo vive en /mnt/c.
API_LINUX_RUN_DIR=/home/<usuario>/seguimiento-api-run-20260307

# Opcional: plantilla oficial para generar solicitudes de auditor en Moodle.
MOODLE_AUDITOR_TEMPLATE_PATH=/ruta/al/FORMATO CREACION DE USUARIOS OFICIAL.xlsx
